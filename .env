# =====================================================
# EduSaaS RD — Variables de entorno
# Copia este archivo como ".env" y rellena tus valores
# =====================================================

# Aplicación
APP_NAME="EduSaaS RD"
APP_URL=http://localhost/edusaas-rd/public
APP_ENV=development
APP_DEBUG=true

# Base de datos
DB_HOST=localhost
DB_NAME=edusaas_rd
DB_USER=root
DB_PASS=

# ── Email SMTP ──────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_FROM_NAME="EduSaaS RD"
MAIL_FROM_EMAIL=ronerjborg@gmail.com
MAIL_REPLY_TO=soporte@edusaas.do

# Gmail SMTP
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_ENCRYPTION=tls
MAIL_SMTP_USER=ronerjborg@gmail.com
MAIL_SMTP_PASSWORD=nqwvhulnouenbcyz
# ↑ Contraseña de aplicación de Google (NO tu contraseña normal)
# Obtener en: myaccount.google.com → Seguridad → Contraseñas de aplicaciones

